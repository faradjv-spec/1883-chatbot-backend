# Exely API Configuration
EXELY_BASE_URL=https://connect.hopenapi.com
EXELY_API_KEY=your_key_here
EXELY_PROPERTY_ID=your_property_id

# Google Maps API
GOOGLE_MAPS_API_KEY=your_key_here

# Exchange Rate API (optional)
EXCHANGE_RATE_API_KEY=your_key_here

# Hotel coordinates (Baku, Azerbaijan)
HOTEL_LAT=40.3777
HOTEL_LNG=49.8533

# CORS - allowed origins (comma-separated)
ALLOWED_ORIGINS=https://www.1883boutiquehotel.com,https://1883boutiquehotel.com

# Server port (Railway injects PORT automatically)
PORT=3000